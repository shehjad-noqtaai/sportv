# apps/web — copy to apps/web/.env.local
NEXT_PUBLIC_SANITY_PROJECT_ID=xqsr0go8
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only (never expose to client)
SANITY_API_READ_TOKEN=

# On-demand ISR (PRD §6.5) — create in Sanity webhook config
SANITY_REVALIDATE_SECRET=

# apps/studio — copy to apps/studio/.env (optional for local dev; CLI may use sanity login)
SANITY_STUDIO_PROJECT_ID=xqsr0go8
SANITY_STUDIO_DATASET=production
